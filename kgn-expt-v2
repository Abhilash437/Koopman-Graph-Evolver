             z_t = encoder(edge_index, num_nodes=n_nodes)\n                    latent_seq.append(z_t.squeeze(0).cpu().numpy())\n\n            latent_seq = np.array(latent_seq)  # (20, latent_dim)\n            torch.save(torch.from_numpy(latent_seq).float(),\n                      latent_dir / f'seed_{seed}.pt')\n\n        print(f\"  ✓ {variant_name} latent_dim={latent_dim}: shape {latent_seq.shape}\")\n\nprint(f\"\\n✓ All graphs encoded! Latent trajectories saved to {LATENT_DIR}\")","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["\n","Encoding all graphs to latent space...\n","\n","  ✓ SBM-2c latent_dim=16: shape (100, 16)\n","  ✓ SBM-2c latent_dim=32: shape (100, 32)\n","  ✓ SBM-2c latent_dim=64: shape (100, 64)\n","  ✓ SBM-2c latent_dim=128: shape (100, 128)\n","  ✓ SBM-3c latent_dim=16: shape (100, 16)\n","  ✓ SBM-3c latent_dim=32: shape (100, 32)\n","  ✓ SBM-3c latent_dim=64: shape (100, 64)\n","  ✓ SBM-3c latent_dim=128: shape (100, 128)\n","  ✓ SBM-4c latent_dim=16: shape (100, 16)\n","  ✓ SBM-4c latent_dim=32: shape (100, 32)\n","  ✓ SBM-4c latent_dim=64: shape (100, 64)\n","  ✓ SBM-4c latent_dim=128: shape (100, 128)\n","  ✓ SBM-2c-periodic latent_dim=16: shape (100, 16)\n","  ✓ SBM-2c-periodic latent_dim=32: shape (100, 32)\n","  ✓ SBM-2c-periodic latent_dim=64: shape (100, 64)\n","  ✓ SBM-2c-periodic latent_dim=128: shape (100, 128)\n","  ✓ SBM-2c-drift latent_dim=16: shape (100, 16)\n","  ✓ SBM-2c-drift latent_dim=32: shape (100, 32)\n","  ✓ SBM-2c-drift latent_dim=64: shape (100, 64)\n","  ✓ SBM-2c-drift latent_dim=128: shape (100, 128)\n","  ✓ SBM-Dynamic-Hard latent_dim=16: shape (100, 16)\n","  ✓ SBM-Dynamic-Hard latent_dim=32: shape (100, 32)\n","  ✓ SBM-Dynamic-Hard latent_dim=64: shape (100, 64)\n","  ✓ SBM-Dynamic-Hard latent_dim=128: shape (100, 128)\n","  ✓ SBM-Signal-Strong latent_dim=16: shape (100, 16)\n","  ✓ SBM-Signal-Strong latent_dim=32: shape (100, 32)\n","  ✓ SBM-Signal-Strong latent_dim=64: shape (100, 64)\n","  ✓ SBM-Signal-Strong latent_dim=128: shape (100, 128)\n","  ✓ SBM-Signal-Medium latent_dim=16: shape (100, 16)\n","  ✓ SBM-Signal-Medium latent_dim=32: shape (100, 32)\n","  ✓ SBM-Signal-Medium latent_dim=64: shape (100, 64)\n","  ✓ SBM-Signal-Medium latent_dim=128: shape (100, 128)\n","  ✓ SBM-Signal-Weak latent_dim=16: shape (100, 16)\n","  ✓ SBM-Signal-Weak latent_dim=32: shape (100, 32)\n","  ✓ SBM-Signal-Weak latent_dim=64: shape (100, 64)\n","  ✓ SBM-Signal-Weak latent_dim=128: shape (100, 128)\n","\n","✓ All graphs encoded! Latent trajectories saved to /content/drive/MyDrive/koopman-graph-evolver-phase3-long-horizon-a/latent\n"]}],"execution_count":7},{"cell_type":"code","source":"# ===== CELL 7: TRANSITION MODEL DEFINITIONS (RESEARCH-GRADE) =====\n\nimport torch\nimport torch.nn as nn\n\n\n# ================================\n# Base Class (optional but clean)\n# ================================\nclass BaseTransitionModel(nn.Module):\n    def reset_hidden(self, batch_size, device):\n        return None\n\n\n# ================================\n# 1. KOOPMAN (LINEAR)\n# ================================\nclass KoopmanLinearSingleStep(nn.Module):\n    \"\"\"z_{t+1} = K z_t\"\"\"\n    def __init__(self, latent_dim):\n        super().__init__()\n        self.K = nn.Linear(latent_dim, latent_dim, bias=False)\n\n    def forward(self, z_t):\n        return self.K(z_t)\n\n\nclass KoopmanLinearStateful(nn.Module):\n    \"\"\"\n    h_{t+1} = A h_t + B z_t\n    z_{t+1} = C h_{t+1}\n    \"\"\"\n    def __init__(self, latent_dim, hidden_dim=64):\n        super().__init__()\n        self.A = nn.Linear(hidden_dim, hidden_dim, bias=False)\n        self.B = nn.Linear(latent_dim, hidden_dim, bias=False)\n        self.C = nn.Linear(hidden_dim, latent_dim)\n\n        self.hidden_dim = hidden_dim\n\n    def forward(self, z_t, h_t=None):\n        if h_t is None:\n            h_t = torch.zeros(z_t.shape[0], self.hidden_dim, device=z_t.device)\n\n        h_next = self.A(h_t) + self.B(z_t)\n        z_next = self.C(h_next)\n\n        return z_next, h_next\n\nclass KoopmanEDMDLift(nn.Module):\n    \"\"\"EDMD with quadratic feature lift: φ(z) = [z, z²]\"\"\"\n    def __init__(self, latent_dim):\n        super().__init__()\n        phi_dim = latent_dim * 2\n        self.K = nn.Linear(phi_dim, phi_dim, bias=False)\n        self.latent_dim = latent_dim\n\n    def lift(self, z):\n        return torch.cat([z, z**2], dim=-1)\n\n    def forward(self, z):\n        return self.lift(self.K(self.lift(z)))[:, :self.latent_dim]\n\n    def spectral_loss(self):\n        evals = torch.linalg.eigvals(self.K.weight)\n        return torch.relu(torch.max(torch.abs(evals)) - 0.9) ** 2\n\n\n# ================================\n# 2. MLP TRANSITION\n# ================================\nclass MLPTransitionSingleStep(nn.Module):\n    \"\"\"z_{t+1} = MLP(z_t)\"\"\"\n    def __init__(self, latent_dim, hidden_dim=128):\n        super().__init__()\n        self.net = nn.Sequential(\n            nn.Linear(latent_dim, hidden_dim),\n            nn.ReLU(),\n            nn.Linear(hidden_dim, hidden_dim),\n            nn.ReLU(),\n            nn.Linear(hidden_dim, latent_dim)\n        )\n\n    def forward(self, z_t):\n        return self.net(z_t)\n\n\nclass MLPTransitionStateful(nn.Module):\n    \"\"\"\n    h_{t+1} = MLP([h_t, z_t])\n    z_{t+1} = W h_{t+1}\n    \"\"\"\n    def __init__(self, latent_dim, hidden_dim=128):\n        super().__init__()\n        self.hidden_dim = hidden_dim\n\n        self.h_net = nn.Sequential(\n            nn.Linear(hidden_dim + latent_dim, hidden_dim),\n            nn.ReLU(),\n            nn.Linear(hidden_dim, hidden_dim)\n        )\n\n        self.W_out = nn.Linear(hidden_dim, latent_dim)\n\n    def forward(self, z_t, h_t=None):\n        if h_t is None:\n            h_t = torch.zeros(z_t.shape[0], self.hidden_dim, device=z_t.device)\n\n        inp = torch.cat([h_t, z_t], dim=-1)\n        h_next = self.h_net(inp)\n        z_next = self.W_out(h_next)\n\n        return z_next, h_next\n\n\n# ================================\n# 3. GRU\n# ================================\nclass GRUTransitionSingleStep(nn.Module):\n    \"\"\"Stateless GRU (no memory carried)\"\"\"\n    def __init__(self, latent_dim):\n        super().__init__()\n        self.gru_cell = nn.GRUCell(latent_dim, latent_dim)\n\n    def forward(self, z_t):\n        h = torch.zeros(z_t.shape[0], z_t.shape[1], device=z_t.device)\n        return self.gru_cell(z_t, h)\n\n\nclass GRUTransitionStateful(nn.Module):\n    \"\"\"Proper GRU dynamics\"\"\"\n    def __init__(self, latent_dim, hidden_dim=128):\n        super().__init__()\n        self.gru_cell = nn.GRUCell(latent_dim, hidden_dim)\n        self.W_out = nn.Linear(hidden_dim, latent_dim)\n        self.hidden_dim = hidden_dim\n\n    def forward(self, z_t, h_t=None):\n        if h_t is None:\n            h_t = torch.zeros(z_t.shape[0], self.hidden_dim, device=z_t.device)\n\n        h_next = self.gru_cell(z_t, h_t)\n        z_next = self.W_out(h_next)\n\n        return z_next, h_next\n\n\n# ================================\n# 4. VANILLA RNN\n# ================================\nclass RNNTransitionSingleStep(nn.Module):\n    def __init__(self, latent_dim):\n        super().__init__()\n        self.W = nn.Linear(latent_dim, latent_dim)\n\n    def forward(self, z_t):\n        return torch.tanh(self.W(z_t))\n\n\nclass RNNTransitionStateful(nn.Module):\n    \"\"\"\n    h_{t+1} = tanh(W_h h_t + W_z z_t)\n    z_{t+1} = W_out h_{t+1}\n    \"\"\"\n    def __init__(self, latent_dim, hidden_dim=128):\n        super().__init__()\n        self.W_h = nn.Linear(hidden_dim, hidden_dim)\n        self.W_z = nn.Linear(latent_dim, hidden_dim)\n        self.W_out = nn.Linear(hidden_dim, latent_dim)\n\n        self.hidden_dim = hidden_dim\n\n    def forward(self, z_t, h_t=None):\n        if h_t is None:\n            h_t = torch.zeros(z_t.shape[0], self.hidden_dim, device=z_t.device)\n\n        h_next = torch.tanh(self.W_h(h_t) + self.W_z(z_t))\n        z_next = self.W_out(h_next)\n\n        return z_next, h_next\n\n\nprint(\"✓ Transition models (research-grade) loaded\")","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["✓ Transition models (research-grade) loaded\n"]}],"execution_count":8},{"cell_type":"code","source":"# ===== CELL 8: MODEL DISPATCHER & UTILITIES =====\n\ndef get_model_class(model_name, mode):\n    \"\"\"Return model class for given (model_name, mode) pair.\"\"\"\n    mapping = {\n        ('Koopman', 'single_step'): KoopmanLinearSingleStep,\n        ('Koopman', 'stateful'): KoopmanLinearStateful,\n        ('MLP', 'single_step'): MLPTransitionSingleStep,\n        ('MLP', 'stateful'): MLPTransitionStateful,\n        ('GRU', 'single_step'): GRUTransitionSingleStep,\n        ('GRU', 'stateful'): GRUTransitionStateful,\n        ('RNN', 'single_step'): RNNTransitionSingleStep,\n        ('RNN', 'stateful'): RNNTransitionStateful,\n        ('EDMD-lift', 'single_step'): KoopmanEDMDLift,\n    }\n    return mapping[(model_name, mode)]\n\n\ndef create_data_loader(latent_trajectory, batch_size=16, train_split=0.75):\n    \"\"\"Create train/test DataLoaders from latent trajectory (single-step mode).\"\"\"\n    z = torch.from_numpy(latent_trajectory).float()\n\n    # Create (z_t, z_{t+1}) pairs\n    z_in = z[:-1]  # (T-1, latent_dim)\n    z_out = z[1:]  # (T-1, latent_dim)\n\n    n_train = int(len(z_in) * train_split)\n\n    train_dataset = TensorDataset(z_in[:n_train], z_out[:n_train])\n    test_dataset = TensorDataset(z_in[n_train:], z_out[n_train:])\n\n    train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True)\n    test_loader = DataLoader(test_dataset, batch_size=batch_size, shuffle=False)\n\n    return train_loader, test_loader\n\n\ndef create_sequence_data_loader(latent_trajectory, batch_size=16, train_split=0.75):\n    \"\"\"Create train/test loaders preserving sequence order (stateful mode).\"\"\"\n\n    z = torch.from_numpy(latent_trajectory).float()\n\n    # 🔥 CRITICAL FIX: ensure (T, latent_dim)\n    if z.dim() == 1:\n        z = z.unsqueeze(-1)\n\n    assert z.dim() == 2, f\"Expected (T, latent_dim), got {z.shape}\"\n\n    T, latent_dim = z.shape\n\n    n_train = int(T * train_split)\n\n    # Edge case safety\n    n_train = max(2, n_train)  # need at least 2 timesteps\n\n    z_train = z[:n_train].unsqueeze(0)   # (1, T_train, latent_dim)\n    z_test = z[n_train:].unsqueeze(0)    # (1, T_test, latent_dim)\n\n    # 🔥 OPTIONAL BUT IMPORTANT: avoid empty test\n    if z_test.shape[1] < 2:\n        z_test = z[-2:].unsqueeze(0)\n\n    # 🔥 KEEP YOUR DESIGN (list-based loader)\n    train_loader = [z_train]\n    test_loader = [z_test]\n\n    return train_loader, test_loader\n\n\ndef compute_loss(z_pred, z_true, model, spectral_penalty_weight=0.1):\n    \"\"\"Compute loss with optional spectral penalty for Koopman models.\"\"\"\n    recon_loss = F.mse_loss(z_pred, z_true)\n\n    if hasattr(model, 'spectral_loss'):\n        spec_loss = model.spectral_loss()\n    else:\n        spec_loss = torch.tensor(0.0, device=z_pred.device)\n\n    return recon_loss + spectral_penalty_weight * spec_loss\n\n\nprint(\"✓ Utility functions defined\")","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["✓ Utility functions defined\n"]}],"execution_count":9},{"cell_type":"code","source":"# ===== CELL 9: TRAINING FUNCTION WITH ROLLOUT LOSS (UPDATED) =====\n\ndef train_single_model(\n    model, train_loader, test_loader,\n    mode='single_step',\n    epochs=50,\n    learning_rate=1e-3,\n    weight_decay=1e-4,\n    spectral_penalty_weight=0.1,\n    rollout_weight=0.3,      # 👈 NEW\n    rollout_steps=2,         # 👈 NEW\n    patience=15,\n    verbose=False\n):\n    optimizer = Adam(model.parameters(), lr=learning_rate, weight_decay=weight_decay)\n    scheduler = torch.optim.lr_scheduler.StepLR(optimizer, step_size=20, gamma=0.9)\n\n    best_test_loss = float('inf')\n    best_state = None\n    patience_counter = 0\n    history = {'train_loss': [], 'test_loss': []}\n\n    model.train()\n\n    for epoch in range(epochs):\n        train_loss = 0.0\n        n_batches = 0\n\n        # ================================\n        # TRAINING\n        # ================================\n        if mode == 'single_step':\n            for z_in, z_out in train_loader:\n                z_in, z_out = z_in.to(DEVICE), z_out.to(DEVICE)\n\n                z_pred = model(z_in)\n\n                # 🔥 SHAPE FIX\n                if z_out.dim() == 1:\n                    z_out = z_out.unsqueeze(-1)\n                if z_pred.dim() == 1:\n                    z_pred = z_pred.unsqueeze(-1)\n\n                # Base loss\n                loss = compute_loss(z_pred, z_out, model, spectral_penalty_weight)\n\n                # =========================\n                # NEW: rollout loss (approximate)\n                # =========================\n                if rollout_steps > 1:\n                    z_roll = z_pred\n                    rollout_loss = 0.0\n\n                    for k in range(1, rollout_steps):\n                        z_roll = model(z_roll)\n                        rollout_loss += F.mse_loss(z_roll, z_out)  # approximation\n\n                    rollout_loss /= (rollout_steps - 1)\n                    loss = loss + rollout_weight * rollout_loss\n\n                optimizer.zero_grad()\n                loss.backward()\n                optimizer.step()\n\n                train_loss += loss.item()\n                n_batches += 1\n\n        else:  # ===== STATEFUL (AUTOREGRESSIVE + ROLLOUT) =====\n            for seq_batch in train_loader:\n                seq_batch = seq_batch.to(DEVICE)  # (batch, T, latent_dim)\n                batch_size, seq_len, _ = seq_batch.shape\n\n                z_curr = seq_batch[:, 0, :]\n                h_t = None\n\n                seq_loss = 0.0\n\n                for t in range(1, seq_len):\n                    z_pred, h_t = model(z_curr, h_t)\n                    z_true = seq_batch[:, t]\n\n                    # 🔥 SHAPE FIX\n                    if z_true.dim() == 1:\n                        z_true = z_true.unsqueeze(-1)\n                    if z_pred.dim() == 1:\n                        z_pred = z_pred.unsqueeze(-1)\n\n                    assert z_pred.shape == z_true.shape, \\\n                        f\"Shape mismatch: pred {z_pred.shape}, true {z_true.shape}\"\n\n                    # Base loss\n                    loss = compute_loss(z_pred, z_true, model, spectral_penalty_weight)\n\n                    # =========================\n                    # NEW: TRUE rollout loss\n                    # =========================\n                    if rollout_steps > 1 and t + rollout_steps < seq_len:\n                        z_roll = z_pred\n                        h_roll = h_t\n                        rollout_loss = 0.0\n\n                        for k in range(1, rollout_steps):\n                            z_roll, h_roll = model(z_roll, h_roll)\n                            z_future = seq_batch[:, t + k]\n\n                            if z_future.dim() == 1:\n                                z_future = z_future.unsqueeze(-1)\n\n                            rollout_loss += F.mse_loss(z_roll, z_future)\n\n                        rollout_loss /= rollout_steps\n                        loss = loss + rollout_weight * rollout_loss\n\n                    seq_loss += loss\n                    z_curr = z_pred  # autoregressive\n\n                seq_loss /= (seq_len - 1)\n\n                optimizer.zero_grad()\n                seq_loss.backward()\n                optimizer.step()\n\n                train_loss += seq_loss.item()\n                n_batches += 1\n\n        train_loss /= n_batches\n        history['train_loss'].append(train_loss)\n\n        # ================================\n        # EVALUATION (UNCHANGED)\n        # ================================\n        model.eval()\n        test_loss = 0.0\n        n_test = 0\n\n        with torch.no_grad():\n            if mode == 'single_step':\n                for z_in, z_out in test_loader:\n                    z_in, z_out = z_in.to(DEVICE), z_out.to(DEVICE)\n\n                    z_pred = model(z_in)\n\n                    if z_out.dim() == 1:\n                        z_out = z_out.unsqueeze(-1)\n                    if z_pred.dim() == 1:\n                        z_pred = z_pred.unsqueeze(-1)\n\n                    loss = compute_loss(z_pred, z_out, model, spectral_penalty_weight)\n\n                    test_loss += loss.item() * len(z_in)\n                    n_test += len(z_in)\n\n            else:\n                for seq_batch in test_loader:\n                    seq_batch = seq_batch.to(DEVICE)\n                    batch_size, seq_len, _ = seq_batch.shape\n\n                    z_curr = seq_batch[:, 0, :]\n                    h_t = None\n\n                    for t in range(1, seq_len):\n                        z_pred, h_t = model(z_curr, h_t)\n                        z_true = seq_batch[:, t]\n\n                        if z_true.dim() == 1:\n                            z_true = z_true.unsqueeze(-1)\n                        if z_pred.dim() == 1:\n                            z_pred = z_pred.unsqueeze(-1)\n\n                        loss = compute_loss(z_pred, z_true, model, spectral_penalty_weight)\n\n                        test_loss += loss.item()\n                        n_test += 1\n\n                        z_curr = z_pred\n\n        test_loss /= n_test\n        history['test_loss'].append(test_loss)\n\n        # ================================\n        # EARLY STOPPING\n        # ================================\n        if test_loss < best_test_loss:\n            best_test_loss = test_loss\n            best_state = model.state_dict().copy()\n            patience_counter = 0\n        else:\n            patience_counter += 1\n\n        scheduler.step()\n        model.train()\n\n        if verbose and (epoch + 1) % 10 == 0:\n            print(f\"    Epoch {epoch+1}/{epochs}: train={train_loss:.4f}, test={test_loss:.4f}\")\n\n        if patience_counter >= patience:\n            if verbose:\n                print(f\"    Early stopping at epoch {epoch+1} (best test_loss={best_test_loss:.4f})\")\n            break\n\n    if best_state is not None:\n        model.load_state_dict(best_state)\n\n    model.eval()\n    return history","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def compute_f1_from_latent(z_pred, adj_true, decoder):\n    \"\"\"Compute F1 by decoding predicted latent and comparing to true adjacency.\"\"\"\n\n    # Ensure tensor\n    if not isinstance(z_pred, torch.Tensor):\n        z_pred = torch.from_numpy(z_pred)\n\n    z_pred = z_pred.float().to(DEVICE)\n\n    # 🔥 FORCE batch dimension (THIS is the key fix)\n    if z_pred.dim() == 1:\n        z_pred = z_pred.unsqueeze(0)   # (1, latent_dim)\n\n    # Decode\n    with torch.no_grad():\n        adj_pred = decoder.reconstruct_adjacency(z_pred)\n\n        # 🔥 Take first graph from batch\n        if adj_pred.dim() == 3:\n            adj_pred = adj_pred[0]\n\n        adj_pred = adj_pred.cpu().numpy()\n\n    # Handle adj_true\n    if isinstance(adj_true, torch.Tensor):\n        adj_true = adj_true.cpu().numpy()\n\n    # Binarize\n    pred_binary = (adj_pred >= 0.5).astype(int)\n    true_binary = (adj_true >= 0.5).astype(int)\n\n    f1 = f1_score(true_binary.flatten(), pred_binary.flatten(), zero_division=0)\n    return f1","metadata":{},"outputs":[],"execution_count":11},{"cell_type":"code","source":"# ===== CELL 10 & 13 COMBINED: TRAIN + EVALUATE ALL MODELS =====\n\nMODEL_NAMES = ['Koopman', 'EDMD-lift', 'MLP', 'GRU', 'RNN']\nMODES = ['single_step', 'stateful']\nHIDDEN_DIM = 64\nSPECTRAL_PENALTY = 0.1\nEVAL_STEPS = [1, 5, 10, 15, 20, 50]\nTRAIN_SEEDS = [0, 1, 2]\nTEST_SEEDS = [3, 4]\n\n# Master list to store EVERY evaluation row for the final CSV\nall_rows = []\n\ntotal_configs = len(SBM_VARIANTS) * len(MODEL_NAMES) * len(MODES) * len(LATENT_DIMS) * N_SEEDS\nconfig_count = 0\nstart_time = time.time()\n\nwith tqdm(total=total_configs, desc=\"Overall Progress\") as pbar:\n    for variant in SBM_VARIANTS.keys():\n        # Load Decoder once per variant (since n_nodes is variant-specific)\n        n_nodes = SBM_VARIANTS[variant]['n_nodes']\n\n        for latent_dim in LATENT_DIMS:\n            # Load the specific decoder for this n_nodes/latent_dim\n            decoder_path = MODELS_DIR / f\"n_nodes={n_nodes}\" / f\"latent_dim={latent_dim}\" / \"decoder.pt\"\n            decoder = GraphDecoder(latent_dim, n_nodes).to(DEVICE)\n            decoder.load_state_dict(torch.load(decoder_path))\n            decoder.eval()\n\n            for model_name in MODEL_NAMES:\n                for mode in MODES:\n                    if mode == 'stateful' and model_name == 'EDMD-lift':\n                        continue\n                    for seed in range(N_SEEDS):\n                        config_count += 1\n\n                        # 1. DATA LOADING (TRAIN/TEST LATENTS)\n                        train_latents = [torch.load(LATENT_DIR / variant / f'latent_dim={latent_dim}' / f'seed_{s}.pt').numpy() for s in TRAIN_SEEDS]\n                        test_latents = [torch.load(LATENT_DIR / variant / f'latent_dim={latent_dim}' / f'seed_{s}.pt').numpy() for s in TEST_SEEDS]\n\n                        train_latent_traj = np.concatenate(train_latents, axis=0)\n                        test_latent_traj = np.concatenate(test_latents, axis=0)\n\n                        if mode == 'stateful':\n                            train_loader, _ = create_sequence_data_loader(train_latent_traj, batch_size=16, train_split=0.8)\n                            _, test_loader = create_sequence_data_loader(test_latent_traj, batch_size=16, train_split=0.8)\n                        else:\n                            train_loader, _ = create_data_loader(train_latent_traj, batch_size=16, train_split=0.8)\n                            _, test_loader = create_data_loader(test_latent_traj, batch_size=16, train_split=0.8)\n\n                        # 2. MODEL CREATION & TRAINING\n                        model_class = get_model_class(model_name, mode)\n                        model = model_class(latent_dim, hidden_dim=HIDDEN_DIM).to(DEVICE) if mode == 'stateful' else model_class(latent_dim).to(DEVICE)\n\n                        history = train_single_model(model, train_loader, test_loader, mode=mode, epochs=50, learning_rate=1e-3, spectral_penalty_weight=SPECTRAL_PENALTY, verbose=False)\n\n                        # 3. SAVE MODEL CHECKPOINT\n                        checkpoint_name = f\"{variant}_latent={latent_dim}_{model_name}_{mode}_seed={seed}.pt\"\n                        torch.save(model.state_dict(), MODELS_DIR / checkpoint_name)\n\n                        # 4. EVALUATION (ROLLOUT & F1)\n                        model.eval()\n                        with torch.no_grad():\n                            for t_seed in TEST_SEEDS:\n                                l_path = LATENT_DIR / variant / f'latent_dim={latent_dim}' / f'seed_{t_seed}.pt'\n                                g_path = DATA_DIR / variant / f'seed_{t_seed}' / 'graphs.pt'\n                                latent_seq = torch.load(l_path).to(DEVICE)\n                                graphs = torch.load(g_path)\n\n                                T = len(graphs)\n                                max_step = max(EVAL_STEPS)\n\n                                for start_t in range(T - max_step):\n                                    # Initial state for rollout\n                                    z_curr = latent_seq[start_t].unsqueeze(0)\n                                    h_curr = None\n                                    z_preds = []\n\n                                    # Rollout for max steps\n                                    for _ in range(max_step):\n                                        if mode == 'stateful':\n                                            z_curr, h_curr = model(z_curr, h_curr)\n                                        else:\n                                            z_curr = model(z_curr)\n                                        z_preds.append(z_curr.squeeze(0))\n\n                                    # Score specific steps\n                                    for step in EVAL_STEPS:\n                                        target_t = start_t + step\n                                        z_p = z_preds[step - 1].unsqueeze(0)\n\n                                        # Decode to Adjacency\n                                        logits = decoder(z_p).squeeze(0)\n                                        adj_logits = torch.zeros(n_nodes, n_nodes, device=logits.device)\n                                        triu_idx = torch.triu_indices(n_nodes, n_nodes, offset=1)\n                                        adj_logits[triu_idx[0], triu_idx[1]] = logits\n                                        adj_logits = adj_logits + adj_logits.t()\n\n                                        pred_bin = (torch.sigmoid(adj_logits) >= 0.5).cpu().numpy().astype(int)\n\n                                        adj_true = graphs[target_t]\n                                        if torch.is_tensor(adj_true): adj_true = adj_true.cpu().numpy()\n                                        true_bin = (adj_true >= 0.5).astype(int)\n\n                                        f1 = f1_score(true_bin.flatten(), pred_bin.flatten(), zero_division=0)\n\n                                        # APPEND TO MASTER LIST\n                                        all_rows.append({\n                                            'variant': variant,\n                                            'model': model_name,\n                                            'mode': mode,\n                                            'latent_dim': latent_dim,\n                                            'seed': seed,\n                                            'step': step,\n                                            'f1': f1\n                                        })\n\n                        pbar.update(1)\n                        # Save CSV every 5 configurations just in case of crash\n                        if config_count % 5 == 0:\n                            pd.DataFrame(all_rows).to_csv(RESULTS_DIR / 'comparison_table.csv', index=False)\n\n# FINAL SAVE\ndf_final = pd.DataFrame(all_rows)\ndf_final.to_csv(RESULTS_DIR / 'comparison_table.csv', index=False)\nelapsed = time.time() - start_time\nprint(f\"\\n✓ Completed 600 models in {elapsed/60:.1f} min. Results: {RESULTS_DIR / 'comparison_table.csv'}\")","metadata":{},"outputs":[{"name":"stderr","output_type":"stream","text":["Overall Progress:  90%|█████████ | 1620/1800 [3:00:32<20:03,  6.69s/it]  \n"]},{"name":"stdout","output_type":"stream","text":["\n","✓ Completed 600 models in 180.7 min. Results: /content/drive/MyDrive/koopman-graph-evolver-phase3-long-horizon-a/results/comparison_table.csv\n"]}],"execution_count":12},{"cell_type":"code","source":"# 1. Clean the column names (removes hidden spaces/newlines)\ndf_final.columns = [c.strip() for c in df_final.columns]\n\n# 2. Ensure data types are correct\ndf_final['step'] = pd.to_numeric(df_final['step'], errors='coerce')\ndf_final['f1'] = pd.to_numeric(df_final['f1'], errors='coerce')\n\n# 3. Clean the string values in grouping columns\ndf_final['model'] = df_final['model'].astype(str).str.strip()\ndf_final['mode'] = df_final['mode'].astype(str).str.strip()\n\n# 4. Filter and Group\nstep50 = df_final[df_final['step'] == 50].copy()\n\nif step50.empty:\n    print(\"⚠️ Warning: No data found for Step 50. Check CSV 'step' values.\")\nelse:\n    # Use observed=True to ensure we only look at categories present in the data\n    summary = step50.groupby(['model', 'mode'], observed=True)['f1'].agg(['mean', 'std']).round(4)\n    print(summary.to_string())","metadata":{},"outputs":[{"name