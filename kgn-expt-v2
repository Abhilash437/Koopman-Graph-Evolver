    header = lines[data_start_idx].strip().replace('\\\\', '')\n        csv_content = [header] + [l.strip().replace('\\\\', '') for l in lines[data_start_idx+1:]]\n        df = pd.read_csv(io.StringIO('\\n'.join(csv_content)))\n\n        # Cleanup types\n        df['f1'] = pd.to_numeric(df['f1'], errors='coerce')\n        df['step'] = pd.to_numeric(df['step'], errors='coerce')\n        df['latent_dim'] = pd.to_numeric(df['latent_dim'], errors='coerce')\n        df['model'] = df['model'].astype(str).str.strip()\n        df['mode'] = df['mode'].astype(str).str.strip()\n        df = df.dropna(subset=['f1', 'step'])\n\n        # Filter for Step 50\n        step50 = df[df['step'] == 50].copy()\n        step50['Model_Config'] = step50['model'] + \" (\" + step50['mode'] + \")\"\n\n        # 3. Visualization\n        plt.figure(figsize=(14, 7))\n        sns.set_style(\"whitegrid\")\n        sns.violinplot(data=step50, x='Model_Config', y='f1', inner=None, color=\".9\")\n        sns.stripplot(data=step50, x='Model_Config', y='f1', alpha=0.3, jitter=True)\n        sns.boxplot(data=step50, x='Model_Config', y='f1', width=0.15, boxprops={'zorder': 2})\n        plt.title(\"F1 Distribution at Step 50: Architectural Comparison\", fontsize=16)\n        plt.xticks(rotation=45)\n        plt.tight_layout()\n        plt.show()\n\n        # 4. Efficiency Analysis\n        def estimate_params(row):\n            ld = row['latent_dim']\n            if row['model'] == 'MLP': return (ld**2) * 2\n            if row['model'] == 'RNN': return (ld**2 + ld)\n            if row['model'] == 'GRU': return 3 * (ld**2 + ld)\n            if row['model'] == 'Koopman': return ld**2\n            if row['model'] == 'EDMD': return ld**2\n            return 1\n\n        step50['params_est'] = step50.apply(estimate_params, axis=1)\n        efficiency = step50.groupby(['model', 'mode'])[['f1', 'params_est']].mean()\n        efficiency['F1_per_1k_params'] = (efficiency['f1'] / efficiency['params_est']) * 1000\n\n        print(\"\\n--- Efficiency Leaderboard ---\")\n        print(efficiency.sort_values(by='F1_per_1k_params', ascending=False).round(4))\n\n    else:\n        print(\"CSV Header not found. Please check file formatting.\")\n\nexcept Exception as e:\n    print(f\"Error accessing file: {e}\")","metadata":{},"outputs":[{"data":{"image/png":"","text/plain":["<Figure size 1400x700 with 1 Axes>"]},"metadata":{},"output_type":"display_data"},{"name":"stdout","output_type":"stream","text":["\n","--- Efficiency Leaderboard ---\n","                           f1  params_est  F1_per_1k_params\n","model     mode                                             \n","EDMD-lift single_step  0.2090         1.0          209.0166\n","Koopman   single_step  0.2084      5440.0            0.0383\n","          stateful     0.2082      5440.0            0.0383\n","RNN       single_step  0.2082      5500.0            0.0379\n","          stateful     0.2082      5500.0            0.0379\n","MLP       single_step  0.2082     10880.0            0.0191\n","          stateful     0.2082     10880.0            0.0191\n","GRU       single_step  0.2082     16500.0            0.0126\n","          stateful     0.2082     16500.0            0.0126\n"]}],"execution_count":16},{"cell_type":"code","source":"# In your analysis:\ndf_results_koopman = df[df['model'] == 'Koopman']\ndf_results_edmd = df[df['model'] == 'EDMD-lift']\n\n# At step 50:\nkoopman_f1 = df_results_koopman[df_results_koopman['step'] == 50]['f1'].mean()\nedmd_f1 = df_results_edmd[df_results_edmd['step'] == 50]['f1'].mean()\n\ndelta = edmd_f1 - koopman_f1\nt_stat, p_val = ttest_ind(\n    df_results_edmd[df_results_edmd['step'] == 50]['f1'],\n    df_results_koopman[df_results_koopman['step'] == 50]['f1']\n)\n\nprint(f\"EDMD F1: {edmd_f1:.4f}\")\nprint(f\"Koopman F1: {koopman_f1:.4f}\")\nprint(f\"Δ: {delta:+.4f}, p={p_val:.4f}\")","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["EDMD F1: 0.2090\n","Koopman F1: 0.2083\n","Δ: +0.0007, p=0.0194\n"]}],"execution_count":17},{"cell_type":"code","source":"import os\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport numpy as np\nimport networkx as nx\nfrom torch_geometric.nn import GCNConv\nfrom torch_geometric.utils import from_networkx\n\n# --- 1. SBM GENERATOR DEFINITION ---\ndef generate_dynamic_sbm(n_nodes=100, n_communities=2, p_in=0.3, p_out=0.01,\n                         horizon=100, drift_type='none', switch_prob=0.0,\n                         persistence=1.0, seed=42):\n    \"\"\"Generates a sequence of SBM graphs with community drift and switching.\"\"\"\n    np.random.seed(seed)\n    graphs = []\n\n    # Initialize community assignments\n    communities = np.random.randint(0, n_communities, size=n_nodes)\n\n    for t in range(horizon):\n        # 1. Update Communities (Dynamics)\n        if drift_type == 'linear':\n            # Slowly shift nodes to the next community\n            if t % 10 == 0:\n                idx = np.random.choice(n_nodes, size=int(n_nodes * 0.05))\n                communities[idx] = (communities[idx] + 1) % n_communities\n\n        if switch_prob > 0:\n            # Stochastic switching\n            switch_mask = np.random.random(n_nodes) < switch_prob\n            communities[switch_mask] = np.random.randint(0, n_communities, size=switch_mask.sum())\n\n        # 2. Generate Graph based on current communities\n        G = nx.Graph()\n        G.add_nodes_from(range(n_nodes))\n\n        # Apply persistence: determine which edges to resample\n        for i in range(n_nodes):\n            for j in range(i + 1, n_nodes):\n                is_same = (communities[i] == communities[j])\n                p = p_in if is_same else p_out\n\n                # Simple SBM edge generation\n                if np.random.random() < p:\n                    G.add_edge(i, j)\n\n        graphs.append(G)\n    return graphs\n\n# --- 3. EXTRACTION LOGIC ---\nDEVICE = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nBASE_PATH = '/content/drive/MyDrive/koopman-graph-evolver-phase3-long-horizon-a'\nLATENT_DIM = 64 # Based on your previous heatmap\nCHECKPOINT_PATH = os.path.join(BASE_PATH, 'models/n_nodes=100/latent_dim=64')\nRESULTS_DIR = os.path.join(BASE_PATH, 'results')\n\ndef extract_and_save_latents():\n    print(f\"🚀 Loading GraphEncoder weights...\")\n    encoder = GraphEncoder(latent_dim=LATENT_DIM).to(DEVICE)\n    model_file = os.path.join(CHECKPOINT_PATH, 'encoder.pt')\n\n    if not os.path.exists(model_file):\n        print(f\"❌ Error: Could not find {model_file}\")\n        return\n\n    encoder.load_state_dict(torch.load(model_file, map_location=DEVICE))\n    encoder.eval()\n\n    all_z = []\n    print(\"🔄 Encoding test sequences (Seeds 3, 4)...\")\n\n    with torch.no_grad():\n        for seed in [3, 4]:\n            config = SBM_VARIANTS['SBM-Signal-Weak']\n            # Ensure horizon matches your expt (Step 50 or 100)\n            graphs = generate_dynamic_sbm(seed=seed, horizon=100, **config)\n\n            z_list = []\n            for G in graphs:\n                # Convert to PyG data format for GCN\n                pyg_data = from_networkx(G).to(DEVICE)\n                z = encoder(pyg_data.edge_index, G.number_of_nodes())\n                z_list.append(z.cpu().numpy())\n\n            all_z.append(np.array(z_list).squeeze())\n\n    final_latents = np.stack(all_z)\n    np.save(os.path.join(RESULTS_DIR, 'test_latents.npy'), final_latents)\n    print(f\"✅ Success! Saved to {RESULTS_DIR}/test_latents.npy\")\n    print(f\"Final Data Shape: {final_latents.shape}\")\n\n# Execute\nextract_and_save_latents()","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["🚀 Loading GraphEncoder weights...\n","🔄 Encoding test sequences (Seeds 3, 4)...\n","✅ Success! Saved to /content/drive/MyDrive/koopman-graph-evolver-phase3-long-horizon-a/results/test_latents.npy\n","Final Data Shape: (2, 100, 64)\n"]}],"execution_count":62},{"cell_type":"code","source":"from sklearn.linear_model import LinearRegression\nfrom sklearn.metrics import r2_score\n\ndef run_linearity_test():\n    z_data = np.load(os.path.join(RESULTS_DIR, 'test_latents.npy'))\n\n    # Flatten across seeds to see the global \"rule\" of the latent space\n    # X = z at time t, y = z at time t+1\n    X = z_data[:, :-1, :].reshape(-1, LATENT_DIM)\n    y = z_data[:, 1:, :].reshape(-1, LATENT_DIM)\n\n    lin_reg = LinearRegression()\n    lin_reg.fit(X, y)\n    y_pred = lin_reg.predict(X)\n\n    r2 = r2_score(y, y_pred)\n    mse = np.mean((y - y_pred)**2)\n\n    print(\"--- 📊 LATENT LINEARITY RESULTS ---\")\n    print(f\"Linear Fit R² Score: {r2:.4f}\")\n    print(f\"Linear Fit MSE:      {mse:.8f}\")\n\n    if r2 > 0.85:\n        print(\"\\n🔥 INTERPRETATION: High Linearity detected.\")\n        print(\"This explains why Koopman and MLP performed similarly—the encoder\")\n        print(\"has already linearized the dynamics. This is a MAJOR finding for your paper.\")\n    else:\n        print(\"\\n📉 INTERPRETATION: Low Linearity.\")\n        print(\"The dynamics are still non-linear in the latent space, but all models\")\n        print(\"are struggling equally with the stochastic noise.\")\n\nrun_linearity_test()","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["--- 📊 LATENT LINEARITY RESULTS ---\n","Linear Fit R² Score: -0.0529\n","Linear Fit MSE:      0.00000000\n","\n","📉 INTERPRETATION: Low Linearity.\n","The dynamics are still non-linear in the latent space, but all models\n","are struggling equally with the stochastic noise.\n"]}],"execution_count":63},{"cell_type":"code","source":"import seaborn as sns\nimport pandas as pd\nimport matplotlib.pyplot as plt\n\n# --- CONFIGURATION ---\nCSV_PATH = '/content/drive/MyDrive/koopman-graph-evolver-phase3-long-horizon-a/results/comparison_table.csv'\n# ---------------------\n\ndef plot_publication_invariance(path):\n    df = pd.read_csv(path)\n\n    # Filter to s